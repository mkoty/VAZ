# Application
NODE_ENV=development
PORT=3001

# Database (Railway PostgreSQL - Public URL для локальной разработки)
# Скопируйте DATABASE_PUBLIC_URL из Railway
DATABASE_URL=postgresql://postgres:password@gondola.proxy.rlwy.net:59589/railway

# Для production Railway автоматически установит DATABASE_URL (Private URL)

# Email Configuration (Yandex или Gmail)
# Для Gmail: создайте App Password (https://myaccount.google.com/apppasswords)
# Для Yandex: создайте пароль приложения (https://id.yandex.ru/security/app-passwords)
EMAIL_USER=your-email@yandex.ru
EMAIL_PASSWORD=your-app-password
